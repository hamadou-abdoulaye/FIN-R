# ── FIN-R Docker — variables d'environnement ─────────────────────────────
# Copier ce fichier en .env et remplir les valeurs avant de lancer :
#   cp .env.example .env && docker compose up --build

# ── Application ───────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=http://localhost

# Générer avec : php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_32_CHARS_RANDOM_STRING==

# ── Base de données ────────────────────────────────────────────────────────
DB_DATABASE=finr
DB_USERNAME=finr_user
DB_PASSWORD=finr_secret_CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────
# Générer avec : php artisan jwt:secret --show
JWT_SECRET=CHANGE_ME_JWT_SECRET_KEY

# ── WebSockets Reverb ─────────────────────────────────────────────────────
REVERB_APP_ID=finr-app
REVERB_APP_KEY=finr-key-CHANGE_ME
REVERB_APP_SECRET=finr-secret-CHANGE_ME
REVERB_HOST=localhost
REVERB_PORT=8080

# ── Frontend (URLs injectées au build React) ──────────────────────────────
FRONTEND_URL=http://localhost

# ── NLP ───────────────────────────────────────────────────────────────────
NLP_WORKERS=2
